# =============================================================================
# FootLineBot Environment Variables
# =============================================================================
# Copy this file to .env.local for local development
# For Vercel deployment, add these variables in the Vercel dashboard

# =============================================================================
# LINE Messaging API Configuration (REQUIRED)
# =============================================================================
# Get these from LINE Developer Console > Messaging API settings
# https://developers.line.biz/console/

# Channel ID - Found in LINE Developer Console
LINE_CHANNEL_ID=your_channel_id

# Channel Secret - Found in LINE Developer Console (Basic settings)
LINE_CHANNEL_SECRET=your_channel_secret

# Access Token - Long-lived access token from Messaging API settings
# Note: This token expires after a certain period. You may need to refresh it.
LINE_ACCESS_TOKEN=your_access_token

# =============================================================================
# Database Configuration (REQUIRED)
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?schema=public
#
# For local development, you can use:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/footlinebot?schema=public"
#
# For Vercel, use Vercel Postgres or a hosted PostgreSQL like Supabase, Neon, or Railway
# Format: postgresql://user:password@host:port/database?schema=public&sslmode=require

DATABASE_URL="postgresql://user:password@localhost:5432/footlinebot?schema=public"

# =============================================================================
# Application Configuration (OPTIONAL)
# =============================================================================

# Public LINE Channel ID - Used for client-side LINE SDK initialization
# Same as LINE_CHANNEL_ID but exposed to the browser
NEXT_PUBLIC_LINE_CHANNEL_ID=your_channel_id

# Application URL - Used for generating absolute URLs in emails/notifications
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Environment-specific Notes:
# =============================================================================
#
# LOCAL DEVELOPMENT:
# 1. Make sure PostgreSQL is running
# 2. Copy this file to .env.local
# 3. Run: npm run db:generate
# 4. Run: npm run db:push
# 5. Run: npm run dev
#
# VERCEL DEPLOYMENT:
# 1. Deploy to Vercel
# 2. Add all variables (except NEXT_PUBLIC_*) in Vercel Dashboard > Settings > Environment Variables
# 3. Ensure DATABASE_URL points to a production PostgreSQL (e.g., Vercel Postgres, Supabase, Neon)
# 4. Set up LINE webhook URL: https://your-vercel-app.vercel.app/api/line/callback
#
# DATABASE PROVIDER COMPATIBILITY:
# - Prisma supports: PostgreSQL, MySQL, SQLite, SQL Server, MongoDB
# - For Vercel: Vercel Postgres, Supabase, Neon, Railway, PlanetScale (with adapter)
